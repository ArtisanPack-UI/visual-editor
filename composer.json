{
  "name": "artisanpack-ui/visual-editor",
  "description": "package name",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "version": "1.0.0",
  "autoload": {
    "psr-4": {
      "ArtisanPackUI\\VisualEditor\\": "src/",
      "ArtisanPackUI\\VisualEditorRendererBlade\\": "packages/visual-editor-renderer-blade/src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "ArtisanPackUI\\VisualEditorRendererBlade\\Tests\\": "packages/visual-editor-renderer-blade/tests/"
    }
  },
  "authors": [
    {
      "name": "Jacob Martella",
      "email": "me@jacobmartella.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": ">=5.3",
    "artisanpack-ui/core": "^1.0"
  },
  "require-dev": {
    "pestphp/pest": "^3.8",
    "pestphp/pest-plugin-laravel": "^3.1",
    "orchestra/testbench": "^10.2"
  },
  "suggest": {
    "artisanpack-ui/media-library": "^1.2 — Default media library integration. Wire MediaModal + uploadMedia through registerArtisanpackMediaBridge() in the editor bootstrap to power Gutenberg's media picker and upload flows."
  },
  "scripts": {
    "test": "./vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ArtisanPackUI\\VisualEditor\\VisualEditorServiceProvider"
      ],
      "aliases": {
        "VisualEditor": "ArtisanPackUI\\VisualEditor\\Facades\\VisualEditor"
      }
    }
  }
}
