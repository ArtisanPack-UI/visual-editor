{
	"$schema": "../../../block-schema.json",
	"type": "post-title",
	"name": "Post Title",
	"description": "Display the content title with configurable heading level and optional link",
	"icon": "document-text",
	"category": "dynamic",
	"keywords": ["post", "title", "heading", "content", "name"],
	"version": 1,
	"dynamic": true,
	"attributes": {
		"level": {
			"type": "string",
			"source": "content",
			"default": "h1"
		},
		"isLink": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"linkTarget": {
			"type": "string",
			"source": "content",
			"default": "_self"
		},
		"rel": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"textColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"backgroundColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontSize": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontFamily": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontAppearance": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"lineHeight": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"letterSpacing": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textDecoration": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textTransform": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"padding": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"margin": {
			"type": "object",
			"source": "style",
			"default": null
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": "heading",
			"appearance": true,
			"lineHeight": true,
			"letterSpacing": true,
			"decoration": true,
			"letterCase": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"htmlId": true,
		"className": true
	}
}
