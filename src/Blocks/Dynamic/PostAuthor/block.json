{
	"$schema": "../../../block-schema.json",
	"type": "post-author",
	"name": "Post Author",
	"description": "Display the content author with optional avatar and biography",
	"icon": "user-circle",
	"category": "dynamic",
	"keywords": ["post", "author", "avatar", "bio", "writer", "byline"],
	"version": 1,
	"dynamic": true,
	"attributes": {
		"showAvatar": {
			"type": "boolean",
			"source": "content",
			"default": true
		},
		"avatarSize": {
			"type": "string",
			"source": "content",
			"default": "md"
		},
		"showBio": {
			"type": "boolean",
			"source": "content",
			"default": true
		},
		"byline": {
			"type": "string",
			"source": "content",
			"default": "by"
		},
		"isLink": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"textColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"backgroundColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontSize": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontFamily": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontAppearance": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"lineHeight": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"letterSpacing": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textDecoration": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textTransform": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"padding": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"margin": {
			"type": "object",
			"source": "style",
			"default": null
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": "body",
			"appearance": true,
			"lineHeight": true,
			"letterSpacing": true,
			"decoration": true,
			"letterCase": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"htmlId": true,
		"className": true
	}
}
