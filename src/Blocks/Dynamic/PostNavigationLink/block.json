{
	"$schema": "../../../block-schema.json",
	"type": "post-navigation-link",
	"name": "Post Navigation Link",
	"description": "Display a link to the previous or next content item with optional title and arrow indicators",
	"icon": "arrows-right-left",
	"category": "dynamic",
	"keywords": ["post", "navigation", "previous", "next", "link", "adjacent"],
	"version": 1,
	"dynamic": true,
	"attributes": {
		"type": {
			"type": "string",
			"source": "content",
			"default": "previous"
		},
		"label": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"showTitle": {
			"type": "boolean",
			"source": "content",
			"default": true
		},
		"arrow": {
			"type": "string",
			"source": "content",
			"default": "none"
		},
		"taxonomy": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"textColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"backgroundColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontSize": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontFamily": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontAppearance": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"lineHeight": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"letterSpacing": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textDecoration": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textTransform": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"padding": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"margin": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"borderRadius": {
			"type": "string",
			"source": "style",
			"default": null
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": true,
			"appearance": true,
			"lineHeight": true,
			"letterSpacing": true,
			"decoration": true,
			"letterCase": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"border": true,
		"htmlId": true,
		"className": true
	}
}
