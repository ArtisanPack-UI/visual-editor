{
	"$schema": "../../../block-schema.json",
	"type": "post-comments-count",
	"name": "Post Comments Count",
	"description": "Display the number of comments on the current content",
	"icon": "chat-bubble-left-right",
	"category": "dynamic",
	"keywords": ["post", "comments", "count", "replies", "discussion"],
	"version": 1,
	"dynamic": true,
	"attributes": {
		"format": {
			"type": "string",
			"source": "content",
			"default": "short"
		},
		"singular": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"plural": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"showIcon": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"linkToComments": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"textColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"backgroundColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontSize": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontFamily": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontAppearance": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"lineHeight": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"letterSpacing": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textDecoration": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textTransform": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"padding": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"margin": {
			"type": "object",
			"source": "style",
			"default": null
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": "body",
			"appearance": true,
			"lineHeight": true,
			"letterSpacing": true,
			"decoration": true,
			"letterCase": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"htmlId": true,
		"className": true
	}
}
