{
	"$schema": "../../../block-schema.json",
	"type": "post-comments-link",
	"name": "Post Comments Link",
	"description": "Display a link to the comments section with contextual text",
	"icon": "chat-bubble-left",
	"category": "dynamic",
	"keywords": ["post", "comments", "link", "reply", "discussion"],
	"version": 1,
	"dynamic": true,
	"attributes": {
		"text": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"zeroText": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"textColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"backgroundColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontSize": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontFamily": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontAppearance": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"lineHeight": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"letterSpacing": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textDecoration": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textTransform": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"padding": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"margin": {
			"type": "object",
			"source": "style",
			"default": null
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": "body",
			"appearance": true,
			"lineHeight": true,
			"letterSpacing": true,
			"decoration": true,
			"letterCase": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"htmlId": true,
		"className": true
	}
}
