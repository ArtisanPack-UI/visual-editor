{
	"$schema": "../../../block-schema.json",
	"type": "post-time-to-read",
	"name": "Post Time to Read",
	"description": "Display the estimated reading time for the current content",
	"icon": "clock",
	"category": "dynamic",
	"keywords": ["post", "time", "read", "reading", "minutes", "estimate"],
	"version": 1,
	"dynamic": true,
	"attributes": {
		"wordsPerMinute": {
			"type": "integer",
			"source": "content",
			"default": 200
		},
		"prefix": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"suffix": {
			"type": "string",
			"source": "content",
			"default": " min read"
		},
		"textColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"backgroundColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontSize": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontFamily": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontAppearance": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"lineHeight": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"letterSpacing": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textDecoration": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textTransform": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"padding": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"margin": {
			"type": "object",
			"source": "style",
			"default": null
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": "body",
			"appearance": true,
			"lineHeight": true,
			"letterSpacing": true,
			"decoration": true,
			"letterCase": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"htmlId": true,
		"className": true
	}
}
