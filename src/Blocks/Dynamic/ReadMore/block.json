{
	"$schema": "../../../block-schema.json",
	"type": "read-more",
	"name": "Read More",
	"description": "Display a link to the full content page, typically used in query loops with post excerpts",
	"icon": "arrow-top-right-on-square",
	"category": "dynamic",
	"keywords": ["read", "more", "link", "continue", "excerpt", "archive"],
	"version": 1,
	"dynamic": true,
	"attributes": {
		"content": {
			"type": "string",
			"source": "content",
			"default": "Read more"
		},
		"linkTarget": {
			"type": "string",
			"source": "content",
			"default": "_self"
		},
		"showArrow": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"textColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"backgroundColor": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontSize": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontFamily": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"fontAppearance": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"lineHeight": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"letterSpacing": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textDecoration": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"textTransform": {
			"type": "string",
			"source": "style",
			"default": null
		},
		"padding": {
			"type": "object",
			"source": "style",
			"default": null
		},
		"margin": {
			"type": "object",
			"source": "style",
			"default": null
		}
	},
	"supports": {
		"color": {
			"text": true,
			"background": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": true,
			"appearance": true,
			"lineHeight": true,
			"letterSpacing": true,
			"decoration": true,
			"letterCase": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"htmlId": true,
		"className": true
	}
}
