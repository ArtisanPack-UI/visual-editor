{
	"$schema": "../../block-schema.json",
	"type": "gallery",
	"name": "Gallery",
	"description": "Display multiple images in a grid",
	"icon": "squares-2x2",
	"category": "media",
	"keywords": ["images", "photos", "grid"],
	"version": 1,
	"public": true,
	"parent": null,
	"allowedChildren": null,
	"attributes": {
		"images": {
			"type": "array",
			"source": "content",
			"default": []
		},
		"linkBehavior": {
			"type": "string",
			"source": "content",
			"default": "none"
		},
		"columns": {
			"type": "string",
			"source": "style",
			"default": "3"
		},
		"gap": {
			"type": "string",
			"source": "style",
			"default": "medium"
		},
		"captionDisplay": {
			"type": "string",
			"source": "style",
			"default": "below"
		},
		"crop": {
			"type": "boolean",
			"source": "style",
			"default": true
		}
	},
	"supports": {
		"align": ["wide", "full"],
		"color": {
			"text": false,
			"background": false
		},
		"typography": {
			"fontSize": false,
			"fontFamily": false
		},
		"spacing": {
			"margin": false,
			"padding": false
		},
		"border": false,
		"anchor": true,
		"className": true
	}
}
