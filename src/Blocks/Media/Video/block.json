{
	"$schema": "../../block-schema.json",
	"type": "video",
	"name": "Video",
	"description": "Embed a video from YouTube, Vimeo, or upload",
	"icon": "video-camera",
	"category": "media",
	"keywords": ["movie", "film", "youtube", "vimeo"],
	"version": 1,
	"public": true,
	"parent": null,
	"allowedChildren": null,
	"attributes": {
		"url": {
			"type": "url",
			"source": "content",
			"default": ""
		},
		"caption": {
			"type": "rich_text",
			"source": "content",
			"default": ""
		},
		"poster": {
			"type": "url",
			"source": "content",
			"default": ""
		},
		"autoplay": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"loop": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"muted": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"controls": {
			"type": "boolean",
			"source": "content",
			"default": true
		},
		"preload": {
			"type": "string",
			"source": "content",
			"default": "metadata"
		},
		"playInline": {
			"type": "boolean",
			"source": "content",
			"default": false
		},
		"align": {
			"type": "string",
			"source": "style",
			"default": "none"
		}
	},
	"supports": {
		"align": ["wide", "full"],
		"dimensions": {
			"aspectRatio": true,
			"minHeight": true
		},
		"htmlId": true,
		"anchor": true,
		"className": true
	}
}
