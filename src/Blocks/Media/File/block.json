{
	"$schema": "../../block-schema.json",
	"type": "file",
	"name": "File",
	"description": "Add a downloadable file",
	"icon": "document",
	"category": "media",
	"keywords": ["download", "attachment", "pdf"],
	"version": 1,
	"public": true,
	"parent": null,
	"allowedChildren": null,
	"attributes": {
		"url": {
			"type": "url",
			"source": "content",
			"default": ""
		},
		"filename": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"fileSize": {
			"type": "string",
			"source": "content",
			"default": ""
		},
		"showDownloadButton": {
			"type": "boolean",
			"source": "style",
			"default": true
		}
	},
	"supports": {
		"anchor": true,
		"htmlId": true,
		"className": true
	}
}
