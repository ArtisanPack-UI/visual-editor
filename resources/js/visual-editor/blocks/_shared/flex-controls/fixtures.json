                "itemClasses": [],
                "arbitraryRules": [
                    { "className": "ap-gap-y-[16px]", "property": "row-gap", "value": "16px", "breakpoint": "base" },
                    { "className": "ap-gap-x-[1rem]", "property": "column-gap", "value": "1rem", "breakpoint": "base" },
                    { "className": "lg:ap-gap-x-[2rem]", "property": "column-gap", "value": "2rem", "breakpoint": "lg" }
                ]
            }
        },
        {
            "name": "place-content-shorthand",
            "input": {
                "container": {
                    "enabled": { "base": true },
                    "placeContent": { "base": "center" }
