                    "wrap": { "base": "wrap" }
                }
            },
            "expected": {
                "containerClasses": [ "ap-flex", "ap-flex-row", "ap-flex-wrap" ],
                "itemClasses": [],
                "arbitraryRules": []
            }
        },
        {
            "name": "column-reverse",
            "input": {
                "container": {
                    "enabled": { "base": true },
                    "direction": { "base": "column-reverse" }
                }
            },
            "expected": {
                "containerClasses": [ "ap-flex", "ap-flex-col-reverse" ],
                "itemClasses": [],
                "arbitraryRules": []
            }
        },
        {
            "name": "justify-and-items",
            "input": {
                "container": {
                    "enabled": { "base": true },
                    "justifyContent": { "base": "space-between" },
