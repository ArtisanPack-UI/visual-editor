                "itemClasses": [ "md:ap-self-end", "ap-grow-1" ],
                "arbitraryRules": [
                    { "className": "ap-gap-x-[8px]", "property": "column-gap", "value": "8px", "breakpoint": "base" }
                ]
            }
        }
    ]
