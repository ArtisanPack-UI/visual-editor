{
    "_": "Cross-renderer parity fixtures for #595. Each entry maps an artisanpackFlex input to the exact class string and arbitrary-value rules every serializer (TS in editor + Vue + React, PHP in Blade) must produce. Keep this file the single source of truth — editor tests, Blade Pest tests, and renderer vitest suites all consume it.",
    "fixtures": [
        {
            "name": "empty",
            "input": null,
            "expected": {
                "containerClasses": [],
                "itemClasses": [],
                "arbitraryRules": []
            }
        },
        {
            "name": "enabled-base",
            "input": {
                "container": {
                    "enabled": { "base": true }
                }
            },
            "expected": {
                "containerClasses": [ "ap-flex" ],
                "itemClasses": [],
                "arbitraryRules": []
            }
        },
        {
            "name": "direction-and-wrap",
            "input": {
                "container": {
                    "enabled": { "base": true },
