            },
            "expected": {
                "containerClasses": [],
                "itemClasses": [ "ap-order-[-5]" ],
                "arbitraryRules": [
                    { "className": "ap-order-[-5]", "property": "order", "value": "-5", "breakpoint": "base" }
                ]
            }
        },
        {
            "name": "full-mixed",
            "input": {
                "container": {
                    "enabled": { "base": true },
                    "direction": { "base": "row" },
                    "justifyContent": { "base": "center", "lg": "flex-end" },
                    "alignItems": { "base": "stretch" },
                    "gap": { "column": { "base": "8px" } }
