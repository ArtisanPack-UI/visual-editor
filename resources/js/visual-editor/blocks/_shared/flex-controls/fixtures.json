        {
            "name": "align-content-with-wrap",
            "input": {
                "container": {
                    "enabled": { "base": true },
                    "wrap": { "base": "wrap" },
                    "alignContent": { "base": "space-around" }
                }
            },
            "expected": {
                "containerClasses": [ "ap-flex", "ap-flex-wrap", "ap-content-around" ],
                "itemClasses": [],
                "arbitraryRules": []
            }
        },
        {
            "name": "responsive-direction",
            "input": {
                "container": {
                    "enabled": { "base": true },
                    "direction": { "base": "column", "md": "row" }
