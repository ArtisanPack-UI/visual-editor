{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "artisanpack/form",
    "title": "Form",
    "category": "widgets",
    "description": "Embed a form from the artisanpack-ui/forms package.",
    "keywords": [
        "form",
        "contact",
        "lead",
        "submission"
    ],
    "textdomain": "artisanpack-visual-editor",
    "attributes": {
        "formId": {
            "type": "number",
            "default": 0
        }
    },
    "supports": {
        "position": true,
        "artisanpackAnimations": true,
        "className": true,
        "html": false,
        "reusable": true,
        "anchor": true,
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "fontFamily": true,
            "fontStyle": true,
            "fontWeight": true,
            "letterSpacing": true,
            "textTransform": true,
            "textDecoration": true
        },
        "color": {
            "background": true,
            "text": true,
            "link": true,
            "gradients": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true,
            "gradient": true
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true
        }
    }
}
