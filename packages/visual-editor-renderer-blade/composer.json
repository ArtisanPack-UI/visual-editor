{
	"name": "artisanpack-ui/visual-editor-renderer-blade",
	"description": "Server-side Blade renderer for the ArtisanPack UI visual editor. Renders saved block trees into HTML using per-block Blade partials; dynamic blocks invoke their registered DynamicBlock::render() inline.",
	"type": "library",
	"license": "GPL-3.0-or-later",
	"keywords": [
		"laravel",
		"blade",
		"visual-editor",
		"gutenberg",
		"renderer",
		"blocks"
	],
	"authors": [
		{
			"name": "Jacob Martella",
			"email": "me@jacobmartella.com"
		}
	],
	"require": {
		"php": "^8.2",
		"illuminate/support": "^11.0|^12.0|^13.0",
		"illuminate/view": "^11.0|^12.0|^13.0",
		"artisanpack-ui/visual-editor": "^1.0"
	},
	"require-dev": {
		"orchestra/testbench": "^10.2",
		"pestphp/pest": "^3.8",
		"pestphp/pest-plugin-laravel": "^3.1"
	},
	"autoload": {
		"psr-4": {
			"ArtisanPackUI\\VisualEditorRendererBlade\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"ArtisanPackUI\\VisualEditorRendererBlade\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "./vendor/bin/pest"
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"ArtisanPackUI\\VisualEditorRendererBlade\\VisualEditorRendererBladeServiceProvider"
			]
		}
	}
}
